{
  "name": "LifeIsStrangeCall",
  "version": "1.1.0",
  "description": "Life is Strange Call App",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "electron-builder --win --mac --publish never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.lis.call",
    "productName": "LifeIsStrangeCall",
    "asar": true,
    "files": [
      "electron.js",
      "server.js",
      "public/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/installers/BlackHole2ch.pkg",
        "to": "installers/BlackHole2ch.pkg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon_512.png",
      "category": "public.app-category.social-networking",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "installerIcon": "assets/icons/icon.ico"
    },
    "dmg": {
      "title": "LifeIsStrangeCall",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 380,
          "type": "file",
          "path": "fix-mac.command"
        }
      ],
      "window": {
        "width": 540,
        "height": 500
      }
    }
  }
}
